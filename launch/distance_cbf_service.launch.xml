<launch>
    <!-- DistanceCBF using an external SDF service (erl_gp_sdf_msgs/SdfQuery).
         The client is created on the relative name `sdf_query`; remap it
         here to wherever the actual SDF server publishes. -->
    <node pkg="pinocchio_ik" exec="distance_cbf_service" output="screen">
        <remap from="sdf_query" to="/sdf_query"/>
        <remap from="joint_states" to="/joint_states"/>
        <remap from="filtered_joint_velocity" to="/xarm6_velocity_controller/commands"/>
        <remap from="nominal_joint_velocity" to="/xarm6_velocity_controller/commands_nominal"/>
    </node>
</launch>
