<launch>
  <!-- Cartesian-twist → joint-velocity IK. Defaults match the real-arm
       deploy (unprefixed joint names, /joint_states topic). Override the
       args to use it with a prefixed Gazebo setup. -->

  <arg name="end_effector_link" default="link6"
       description="EE link in the URDF the IK targets." />
  <arg name="rate" default="100.0"
       description="Control loop Hz. velocity_ik's watchdog timeout is 3/rate." />
  <arg name="is_world" default="true"
       description="true = twists in world frame; false = EE local frame." />
  <arg name="use_sim_time" default="false" />
  <arg name="watchdog_timeout_sec" default="0.0"
       description="Override the watchdog timeout. 0 → 3/rate seconds." />
  <arg name="controlled_joint_names"
       default="[joint1, joint2, joint3, joint4, joint5, joint6]" />

  <arg name="desired_twist_topic"        default="/cmd_vel" />
  <arg name="joint_states_topic"         default="/joint_states" />
  <arg name="joint_velocity_cmd_topic"   default="/velocity_controller/commands_nominal" />
  <arg name="joint_position_cmd_topic"   default="/position_controller/commands_unused" />
  <arg name="robot_description_topic"    default="/robot_description" />

  <node pkg="pinocchio_ik" exec="velocity_ik" output="screen">
    <param name="end_effector_link" value="$(var end_effector_link)"/>
    <param name="rate" value="$(var rate)"/>
    <param name="is_world" value="$(var is_world)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="watchdog_timeout_sec" value="$(var watchdog_timeout_sec)"/>
    <param name="controlled_joint_names" value="$(var controlled_joint_names)"/>

    <remap from="robot_description" to="$(var robot_description_topic)"/>
    <remap from="joint_states" to="$(var joint_states_topic)"/>
    <remap from="desired_twist" to="$(var desired_twist_topic)"/>
    <remap from="joint_velocity_cmd" to="$(var joint_velocity_cmd_topic)"/>
    <remap from="joint_position_cmd" to="$(var joint_position_cmd_topic)"/>
  </node>
</launch>
